# Firebase Configuration
# Get these from your Firebase project settings: https://console.firebase.google.com
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id

# Google Sign-In Configuration
# Get this from Google Cloud Console: https://console.cloud.google.com
REACT_APP_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Mux Video Configuration
# Get these from your Mux dashboard: https://dashboard.mux.com
REACT_APP_MUX_TOKEN_ID=your_mux_token_id
REACT_APP_MUX_API_KEY=your_mux_api_key

# App Configuration
REACT_APP_ENV=development
REACT_APP_API_URL=https://api.bharatflex.local

# 📋 SETUP INSTRUCTIONS
# =====================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update all values with your actual credentials
# 3. NEVER commit .env to git (already in .gitignore)
# 4. For detailed setup guide, see: ENVIRONMENT_SETUP.md

# ⚠️ SECURITY REMINDER
# Never share or expose these credentials in:
# - Public GitHub repositories
# - Chat applications (Slack, Teams, Discord)
# - Email or documentation
# - Logs or error messages
# If credentials are exposed, rotate them immediately!
